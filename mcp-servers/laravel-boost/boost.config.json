{
  "project": {
    "name": "SM Portal",
    "backendPath": "../../backend",
    "frontendPath": "../../frontend",
    "dockerContainer": "sm_backend",
    "postgresContainer": "sm_postgres",
    "redisContainer": "sm_redis",
    "queueContainer": "sm_queue",
    "nginxContainer": "sm_nginx",
    "docusealContainer": "sm_docuseal"
  },
  "security": {
    "auditFile": "../../INVITATION_SECURITY_AUDIT.md",
    "decisionsFile": "../../CLAUDE.md",
    "decisionsSection": "Security Decisions"
  },
  "artisan": {
    "allowlist": [
      "route:list",
      "model:show",
      "db:table",
      "db:show",
      "make:model",
      "make:controller",
      "make:request",
      "make:resource",
      "make:policy",
      "make:migration",
      "make:test",
      "migrate:status",
      "config:show",
      "about",
      "schedule:list",
      "queue:failed"
    ],
    "blocklist": [
      "migrate",
      "db:wipe",
      "db:seed",
      "down",
      "up",
      "cache:clear",
      "config:clear",
      "tinker",
      "serve"
    ]
  },
  "cache": {
    "enabled": true
  }
}
