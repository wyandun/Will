{
  "name": "laravel-boost",
  "version": "1.0.0",
  "description": "MCP server for Laravel/SM Portal — exposes project structure, routes, DB schema, and quality tools to AI agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
