# SM Portal — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# cp .env.example .env

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="SM Portal"
APP_ENV=local
APP_DEBUG=true

# Generate with: php artisan key:generate --show
APP_KEY=base64:REPLACE_WITH_GENERATED_KEY

APP_URL=http://localhost

# ---------------------------------------------------------------------------
# Database (PostgreSQL 16)
# Shared by Laravel and DocuSeal.
# ---------------------------------------------------------------------------
DB_DATABASE=sm_portal
DB_USERNAME=sm_user
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ---------------------------------------------------------------------------
# Redis 7
# ---------------------------------------------------------------------------
REDIS_PASSWORD=null

# ---------------------------------------------------------------------------
# Queue & Cache (use redis in all environments)
# ---------------------------------------------------------------------------
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# ---------------------------------------------------------------------------
# DocuSeal (self-hosted e-signing)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 64
DOCUSEAL_SECRET_KEY_BASE=REPLACE_WITH_64_CHAR_HEX_SECRET

# Separate database for DocuSeal — must differ from DB_DATABASE so DocuSeal's
# own "users" table does not collide with Laravel's migrations.
DOCUSEAL_DB_DATABASE=sm_docuseal

# URL the Laravel backend uses to call DocuSeal internally (Docker network)
DOCUSEAL_URL=http://docuseal:3000

# ---------------------------------------------------------------------------
# OpenAI (document processing, BPMN AI translation)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-REPLACE_WITH_OPENAI_KEY
OPENAI_MODEL=gpt-4o

# AI confidence threshold — entries below this require manual review
# See critical business rule: AI confidence < 0.70 → manual review
AI_CONFIDENCE_THRESHOLD=0.70

# ---------------------------------------------------------------------------
# Anthropic (news module — Claude Haiku for article summarization)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_ANTHROPIC_KEY
# Override model if needed; default is claude-haiku-4-5-20251001
# ANTHROPIC_NEWS_MODEL=claude-haiku-4-5-20251001

# How often the scheduler auto-fetches news (in hours, default 6)
NEWS_FETCH_INTERVAL_HOURS=6

# ---------------------------------------------------------------------------
# Frontend (Vite)
# Only relevant when running the frontend dev container (--profile dev)
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost/api

# ---------------------------------------------------------------------------
# Mail (local dev: use Mailpit or log driver)
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@smportal.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug
